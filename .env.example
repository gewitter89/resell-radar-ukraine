# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Monitoring intervals (seconds)
CHECK_INTERVAL_MIN_SECONDS=120
CHECK_INTERVAL_MAX_SECONDS=300

# Scoring thresholds
DEAL_SCORE_THRESHOLD=75
RISK_SCORE_MAX=45
DEFAULT_MIN_PROFIT=1000

# PostgreSQL (Docker: docker compose up -d db)
POSTGRES_USER=resell
POSTGRES_PASSWORD=resell_pass
POSTGRES_DB=resell_radar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (Docker: docker compose up -d redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (Docker: docker compose up -d minio)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=resell-radar
MINIO_ENDPOINT=localhost:9000

# DeepSeek API (primary AI for analysis)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Gemini API (fallback AI, optional)
GEMINI_API_KEY=

# OLX Bearer Token (for direct messaging)
OLX_BEARER_TOKEN=
